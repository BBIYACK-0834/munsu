# 금융감독원 금융상품통합비교공시 인증키
# 실제 키는 GitHub에 올리지 말고, 로컬 .env 또는 배포 환경변수에만 저장하세요.
FINLIFE_API_KEY=aa3b73519905d7ad67cc34f2b86df685

# 관리자용 적금 데이터 갱신 토큰
# 예: openssl rand -hex 32
SAVINGS_REFRESH_TOKEN=1234

# 선택: 운영 프론트엔드 주소만 허용하려면 쉼표로 구분해 입력
# 비워두면 개발 편의를 위해 모든 origin을 허용합니다.
# CORS_ORIGIN=http://localhost:3000,https://your-frontend.example.com

# 선택: 권역코드 (020000=은행, 030300=저축은행 등)
FSS_TOP_FIN_GRP_NO=020000

# 선택: 특정 금융회사 코드 또는 이름으로 필터링
# FSS_FINANCE_CD=국민
