# 금융감독원 금융상품통합비교공시 인증키
FINLIFE_API_KEY=

# POST /api/savings/refresh 관리자 갱신 토큰
SAVINGS_REFRESH_TOKEN=

# 코드스페이스/로컬 첫 실행 때 캐시가 없으면 GET /api/savings에서 자동 수집을 시도합니다.
# 자동 수집을 끄려면 false로 설정하세요.
SAVINGS_AUTO_REFRESH_ON_MISS=true

# 운영 프론트엔드 origin만 허용할 때 쉼표로 구분해 입력합니다. 비워두면 모든 origin 허용.
CORS_ORIGIN=

# 선택: 금융권역/금융회사 필터
FSS_TOP_FIN_GRP_NO=020000
FSS_FINANCE_CD=
